# =============================================================================
# GrokDent FL - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application Settings ---
APP_NAME=GrokDent FL
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars

# --- Database ---
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./grokdent.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/grokdent_fl

# --- Encryption (HIPAA Compliance) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# --- xAI / Grok API ---
XAI_API_KEY=xai-your-api-key-here
XAI_BASE_URL=https://api.x.ai/v1

# --- Twilio (Voice & SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+14075551234

# --- Stripe (Billing) ---
STRIPE_SECRET_KEY=your-stripe-test-secret-key-placeholder
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- SendGrid (Email) ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Calendar ---
# Paste full JSON credentials on a single line
GOOGLE_CALENDAR_CREDENTIALS_JSON={}
GOOGLE_CALENDAR_ID=primary
